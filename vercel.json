{
  "version": 2,
  "builds": [
    {
      "src": "craftora-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "craftora-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/craftora-backend/server.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/craftora-frontend/assets/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/craftora-frontend/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/craftora-frontend/index.html"
    }
  ]
}