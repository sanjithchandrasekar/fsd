{
  "version": 2,
  "builds": [
    {
      "src": "craftora-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "craftora-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "cd craftora-frontend && npm install && npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "craftora-backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
