{
  "version": 2,
  "builds": [
    {
      "src": "craftora-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "craftora-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "craftora-frontend/dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "craftora-backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "craftora-frontend/$1"
    }
  ]
}
